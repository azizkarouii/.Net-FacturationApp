@page "/parametres"
@using System.ComponentModel.DataAnnotations
@inject IParametreService ParametreService

<PageTitle>Paramètres</PageTitle>

<div class="container-fluid py-4 app-page">
    <div class="page-header d-flex justify-content-between align-items-end mb-4">
        <div>
            <h1 class="page-title display-6 fw-bold mb-1">Paramètres</h1>
            <p class="page-subtitle mb-0">Configuration de la société et du timbre fiscal.</p>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert alert-info">@Message</div>
    }

    <div class="card surface-card shadow-sm border-0">
        <div class="card-body">
            <EditForm Model="Form" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label class="form-label">Nom société</label>
                        <InputText class="form-control" @bind-Value="Form.NomSociete" />
                        <ValidationMessage For="() => Form.NomSociete" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Matricule fiscal</label>
                        <InputText class="form-control" @bind-Value="Form.MatriculeFiscal" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Téléphone</label>
                        <InputText class="form-control" @bind-Value="Form.Telephone" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Email</label>
                        <InputText class="form-control" @bind-Value="Form.Email" />
                        <ValidationMessage For="() => Form.Email" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Adresse</label>
                        <InputText class="form-control" @bind-Value="Form.Adresse" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Montant du timbre fiscal</label>
                        <InputNumber class="form-control" @bind-Value="Form.MontantTimbre" />
                        <ValidationMessage For="() => Form.MontantTimbre" />
                    </div>
                    <div class="col-12 col-md-6">
                        <label class="form-label">Préfixe des factures</label>
                        <InputText class="form-control" @bind-Value="Form.PrefixeFacture" />
                        <ValidationMessage For="() => Form.PrefixeFacture" />
                    </div>
                    <div class="col-12">
                        <label class="form-label">Mentions légales</label>
                        <InputTextArea class="form-control" rows="4" @bind-Value="Form.MentionsLegales" />
                    </div>
                </div>

                <div class="mt-4">
                    <button type="submit" class="btn btn-success">Enregistrer</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    private ParametreFormModel Form { get; set; } = new();
    private string? Message { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var current = await ParametreService.GetCurrentAsync();
        if (current is not null)
        {
            Form = new ParametreFormModel
            {
                Id = current.Id,
                NomSociete = current.NomSociete,
                Adresse = current.Adresse,
                Telephone = current.Telephone,
                Email = current.Email,
                MatriculeFiscal = current.MatriculeFiscal,
                MontantTimbre = current.MontantTimbre,
                PrefixeFacture = current.PrefixeFacture,
                MentionsLegales = current.MentionsLegales
            };
        }
    }

    private async Task SaveAsync()
    {
        var entity = new Parametre
        {
            Id = Form.Id,
            NomSociete = Form.NomSociete.Trim(),
            Adresse = Form.Adresse,
            Telephone = Form.Telephone,
            Email = Form.Email,
            MatriculeFiscal = Form.MatriculeFiscal,
            MontantTimbre = Form.MontantTimbre,
            PrefixeFacture = Form.PrefixeFacture.Trim(),
            MentionsLegales = Form.MentionsLegales
        };

        await ParametreService.SaveAsync(entity);
        Message = "Paramètres enregistrés avec succès.";
    }

    private sealed class ParametreFormModel
    {
        public int Id { get; set; }

        [Required, MaxLength(200)]
        public string NomSociete { get; set; } = string.Empty;

        public string? Adresse { get; set; }

        [MaxLength(20)]
        public string? Telephone { get; set; }

        [EmailAddress]
        public string? Email { get; set; }

        public string? MatriculeFiscal { get; set; }

        [Range(0, 100)]
        public decimal MontantTimbre { get; set; } = 1.000m;

        [Required, MaxLength(20)]
        public string PrefixeFacture { get; set; } = "FAC-";

        public string? MentionsLegales { get; set; }
    }
}