@page "/dashboard"
@implements IAsyncDisposable
@using FacturationApp.Data.Entities
@using FacturationApp.Services.Contracts
@using FacturationApp.Services.Models
@inject IDashboardService DashboardService
@inject IInnovationService InnovationService
@inject IJSRuntime JS

<PageTitle>Dashboard</PageTitle>

<div class="container-fluid py-4 app-page dashboard-page">
    <div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h1 class="page-title display-6 fw-bold mb-1">Tableau de bord analytique</h1>
            <p class="page-subtitle mb-0">Lecture fiscale et commerciale de l’activité de facturation.</p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label mb-1">Début</label>
                <InputDate class="form-control" @bind-Value="DateDebut" />
            </div>
            <div>
                <label class="form-label mb-1">Fin</label>
                <InputDate class="form-control" @bind-Value="DateFin" />
            </div>
            <button class="btn btn-primary mt-4" @onclick="RefreshAsync">Actualiser</button>
        </div>
    </div>

    @if (IsLoading)
    {
        <div class="alert alert-secondary">Chargement des indicateurs...</div>
    }

    <div class="row g-3 mb-4">
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card metric-primary">
                <div class="card-body">
                    <div class="text-uppercase small text-white-50">TVA collectée</div>
                    <div class="display-6 fw-bold text-white">@Fiscal.TVACollecteeTotale.ToString("N3")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card metric-secondary">
                <div class="card-body">
                    <div class="text-uppercase small text-white-50">Timbre fiscal</div>
                    <div class="display-6 fw-bold text-white">@Fiscal.MontantTimbreTotal.ToString("N3")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card metric-tertiary">
                <div class="card-body">
                    <div class="text-uppercase small text-white-50">CA total HT</div>
                    <div class="display-6 fw-bold text-white">@Sales.ChiffreAffairesTotalHT.ToString("N3")</div>
                </div>
            </div>
        </div>
        <div class="col-12 col-md-6 col-xl-3">
            <div class="card border-0 shadow-sm h-100 metric-card metric-quaternary">
                <div class="card-body">
                    <div class="text-uppercase small text-white-50">Taux de recouvrement</div>
                    <div class="display-6 fw-bold text-white">@Sales.TauxRecouvrement.ToString("N2")%</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-12 col-xl-6">
            <div class="card surface-card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h2 class="h5 mb-0">Tableau de bord fiscal</h2>
                </div>
                <div class="card-body">
                    <div class="chart-wrap mb-3">
                        <div id="vatByRateChart" class="chart-container"></div>
                    </div>
                    <div class="chart-wrap">
                        <div id="vatTrendChart" class="chart-container"></div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card surface-card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h2 class="h5 mb-0">Tableau de bord ventes</h2>
                </div>
                <div class="card-body">
                    <div class="chart-wrap mb-3">
                        <div id="salesPeriodChart" class="chart-container"></div>
                    </div>
                    <div class="chart-wrap">
                        <div id="statusDonutChart" class="chart-container"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-12 col-xl-6">
            <div class="card surface-card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Top 10 clients</h2>
                    <span class="badge text-bg-light">CA TTC</span>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Client</th>
                                <th class="text-end">CA HT</th>
                                <th class="text-end">CA TTC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Sales.ChiffreAffairesParClient)
                            {
                                <tr>
                                    <td>@item.ClientNom</td>
                                    <td class="text-end">@item.ChiffreAffairesHT.ToString("N3")</td>
                                    <td class="text-end">@item.ChiffreAffairesTTC.ToString("N3")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-6">
            <div class="card surface-card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Top 10 produits</h2>
                    <span class="badge text-bg-light">CA TTC</span>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-hover align-middle">
                        <thead>
                            <tr>
                                <th>Produit</th>
                                <th class="text-end">CA HT</th>
                                <th class="text-end">CA TTC</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Sales.ChiffreAffairesParProduit)
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold">@item.Reference</div>
                                        <div class="small text-body-secondary">@item.Designation</div>
                                    </td>
                                    <td class="text-end">@item.ChiffreAffairesHT.ToString("N3")</td>
                                    <td class="text-end">@item.ChiffreAffairesTTC.ToString("N3")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-1">
        <div class="col-12 col-xl-5">
            <div class="card surface-card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Anomalies fiscales</h2>
                    <span class="badge text-bg-danger">@Anomalies.Count</span>
                </div>
                <div class="card-body table-responsive">
                    <table class="table table-sm align-middle">
                        <thead>
                            <tr>
                                <th>Facture</th>
                                <th>Gravité</th>
                                <th>Anomalie</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (Anomalies.Count == 0)
                            {
                                <tr>
                                    <td colspan="3" class="text-center text-body-secondary py-4">Aucune anomalie détectée.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var anomaly in Anomalies.Take(8))
                                {
                                    <tr>
                                        <td>@anomaly.NumeroFacture</td>
                                        <td>
                                            <span class="badge @(anomaly.Gravite == "Critique" ? "text-bg-danger" : anomaly.Gravite == "Moyen" ? "text-bg-warning" : "text-bg-secondary")">
                                                @anomaly.Gravite
                                            </span>
                                        </td>
                                        <td>@anomaly.Message</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Prévision du CA</h2>
                    <span class="badge text-bg-light">Mois prochain: @Forecast.LabelMoisProchain</span>
                </div>
                <div class="card-body">
                    <div class="row g-3 mb-3">
                        <div class="col-12 col-md-4">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="small text-body-secondary text-uppercase">CA prévu</div>
                                <div class="h3 mb-0">@Forecast.PrevisionMoisProchain.ToString("N3")</div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="small text-body-secondary text-uppercase">Dernier mois</div>
                                <div class="h3 mb-0">@Forecast.DernierMois.ToString("N3")</div>
                            </div>
                        </div>
                        <div class="col-12 col-md-4">
                            <div class="p-3 rounded-3 bg-light h-100">
                                <div class="small text-body-secondary text-uppercase">Évolution estimée</div>
                                <div class="h3 mb-0">@Forecast.TauxEvolution.ToString("N2")%</div>
                            </div>
                        </div>
                    </div>
                    <div class="chart-wrap">
                        <div id="forecastChart" class="chart-container"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private DateTime DateDebut { get; set; } = new DateTime(DateTime.UtcNow.Year, 1, 1);
    private DateTime DateFin { get; set; } = DateTime.UtcNow.Date;
    private FiscalDashboardDto Fiscal { get; set; } = new();
    private SalesDashboardDto Sales { get; set; } = new();
    private List<FiscalAnomalyDto> Anomalies { get; set; } = new();
    private RevenueForecastDto Forecast { get; set; } = new();
    private bool IsLoading { get; set; }
    private bool PendingChartRender { get; set; }
    private IJSObjectReference? ChartModule { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (PendingChartRender)
        {
            PendingChartRender = false;
            await RenderChartsAsync();
        }
    }

    private async Task RefreshAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        IsLoading = true;
        StateHasChanged();

        Fiscal = await DashboardService.GetFiscalDashboardAsync(DateDebut, DateFin);
        Sales = await DashboardService.GetSalesDashboardAsync(DateDebut, DateFin);
        Anomalies = await InnovationService.DetectFiscalAnomaliesAsync(DateDebut, DateFin);
        Forecast = await InnovationService.GetRevenueForecastAsync(6);

        IsLoading = false;
        PendingChartRender = true;
        StateHasChanged();
    }

    private async Task RenderChartsAsync()
    {
        ChartModule ??= await JS.InvokeAsync<IJSObjectReference>("import", "/_content/ApexCharts.Blazor/apex-charts-blazor.js");

        await ChartModule.InvokeVoidAsync("createChart", "vatByRateChart", BuildVatByRateOptions(), EmptyExtendedOptions());
        await ChartModule.InvokeVoidAsync("createChart", "vatTrendChart", BuildVatTrendOptions(), EmptyExtendedOptions());
        await ChartModule.InvokeVoidAsync("createChart", "salesPeriodChart", BuildSalesPeriodOptions(), EmptyExtendedOptions());
        await ChartModule.InvokeVoidAsync("createChart", "statusDonutChart", BuildStatusOptions(), EmptyExtendedOptions());
        await ChartModule.InvokeVoidAsync("createChart", "forecastChart", BuildForecastOptions(), EmptyExtendedOptions());
    }

    private object EmptyExtendedOptions() => new
    {
        yFormatExpression = (string?)null,
        dataLabelsFormatExpression = (string?)null
    };

    private object BuildVatByRateOptions()
    {
        var categories = Fiscal.TVAParTaux.Select(item => $"{item.TauxTVA:0.##}%").ToArray();
        var values = Fiscal.TVAParTaux.Select(item => item.MontantTVA).ToArray();

        return new
        {
            chart = new { type = "bar", height = 320, toolbar = new { show = false } },
            series = new[] { new { name = "TVA collectée", data = values } },
            xaxis = new { categories = categories },
            colors = new[] { "#f59e0b" },
            dataLabels = new { enabled = false },
            plotOptions = new { bar = new { borderRadius = 6, horizontal = false, columnWidth = "45%" } },
            grid = new { borderColor = "#e5e7eb" },
            tooltip = new { theme = "light" }
        };
    }

    private object BuildVatTrendOptions()
    {
        var categories = Fiscal.EvolutionTVAParMois.Select(item => item.Periode).ToArray();
        var values = Fiscal.EvolutionTVAParMois.Select(item => item.MontantTVA).ToArray();

        return new
        {
            chart = new { type = "line", height = 320, toolbar = new { show = false } },
            series = new[] { new { name = "TVA par mois", data = values } },
            xaxis = new { categories = categories },
            colors = new[] { "#2563eb" },
            stroke = new { curve = "smooth", width = 3 },
            dataLabels = new { enabled = false },
            grid = new { borderColor = "#e5e7eb" },
            tooltip = new { theme = "light" }
        };
    }

    private object BuildSalesPeriodOptions()
    {
        var categories = Sales.ChiffreAffairesParPeriode.Select(item => item.Periode).ToArray();
        var valuesHt = Sales.ChiffreAffairesParPeriode.Select(item => item.ChiffreAffairesHT).ToArray();
        var valuesTtc = Sales.ChiffreAffairesParPeriode.Select(item => item.ChiffreAffairesTTC).ToArray();

        return new
        {
            chart = new { type = "bar", height = 320, toolbar = new { show = false } },
            series = new[]
            {
                new { name = "CA HT", data = valuesHt },
                new { name = "CA TTC", data = valuesTtc }
            },
            xaxis = new { categories = categories },
            colors = new[] { "#10b981", "#0f766e" },
            plotOptions = new { bar = new { borderRadius = 6, horizontal = false, columnWidth = "45%" } },
            dataLabels = new { enabled = false },
            grid = new { borderColor = "#e5e7eb" },
            tooltip = new { theme = "light" }
        };
    }

    private object BuildStatusOptions()
    {
        var labels = Sales.RepartitionParStatut.Select(item => item.Statut).ToArray();
        var values = Sales.RepartitionParStatut.Select(item => item.NombreFactures).ToArray();

        return new
        {
            chart = new { type = "donut", height = 320 },
            labels = labels,
            series = values,
            colors = new[] { "#f59e0b", "#3b82f6", "#10b981", "#ef4444" },
            legend = new { position = "bottom" },
            dataLabels = new { enabled = true },
            tooltip = new { theme = "light" }
        };
    }

    private object BuildForecastOptions()
    {
        var categories = Forecast.Historique.Select(item => item.Periode).Concat(new[] { Forecast.LabelMoisProchain }).ToArray();
        var realSeries = Forecast.Historique.Select(item => (decimal?)item.MontantHT).Concat(new decimal?[] { null }).ToArray();
        var forecastSeries = Enumerable.Repeat((decimal?)null, Forecast.Historique.Count).Concat(new decimal?[] { Forecast.PrevisionMoisProchain }).ToArray();

        return new
        {
            chart = new { type = "line", height = 320, toolbar = new { show = false } },
            series = new[]
            {
                new { name = "CA réel", data = realSeries },
                new { name = "Prévision", data = forecastSeries }
            },
            xaxis = new { categories = categories },
            colors = new[] { "#0f766e", "#ef4444" },
            stroke = new { curve = "smooth", width = 3 },
            markers = new { size = 4 },
            dataLabels = new { enabled = false },
            grid = new { borderColor = "#e5e7eb" },
            tooltip = new { theme = "light" }
        };
    }

    public async ValueTask DisposeAsync()
    {
        if (ChartModule is not null)
        {
            try
            {
                await ChartModule.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already disconnected (page refresh/navigation), safe to ignore.
            }
        }
    }
}