@page "/produits"
@using System.ComponentModel.DataAnnotations
@inject IProduitService ProduitService
@inject IJSRuntime JSRuntime

<PageTitle>Produits</PageTitle>

<div class="container-fluid py-4 app-page">
    <div class="page-header d-flex flex-wrap justify-content-between align-items-end gap-3 mb-4">
        <div>
            <h1 class="page-title display-6 fw-bold mb-1">Produits</h1>
            <p class="page-subtitle mb-0">Gestion des produits avec taux de TVA par article.</p>
        </div>

        <div class="d-flex flex-wrap gap-2 align-items-end">
            <div>
                <label class="form-label mb-1">Recherche</label>
                <input class="form-control" @bind="SearchTerm" @bind:event="oninput" placeholder="Référence, désignation..." />
            </div>
            <div class="form-check mt-4">
                <input class="form-check-input" type="checkbox" id="showInactiveProducts" @bind="ShowInactive" />
                <label class="form-check-label" for="showInactiveProducts">Inactifs</label>
            </div>
            <button class="btn btn-outline-primary mt-4" @onclick="LoadAsync">Filtrer</button>
            <button class="btn btn-primary mt-4" @onclick="NewProduit">Nouveau produit</button>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Message))
    {
        <div class="alert alert-info">@Message</div>
    }

    <div class="row g-4">
        <div class="col-12 col-xl-5">
            <div class="card surface-card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-3 pb-0">
                    <h2 class="h5 mb-0">@(Form.Id == 0 ? "Créer un produit" : "Modifier le produit")</h2>
                </div>
                <div class="card-body">
                    <EditForm Model="Form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <div class="mb-3">
                            <label class="form-label">Référence</label>
                            <InputText class="form-control" @bind-Value="Form.Reference" />
                            <ValidationMessage For="() => Form.Reference" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Désignation</label>
                            <InputText class="form-control" @bind-Value="Form.Designation" />
                            <ValidationMessage For="() => Form.Designation" />
                        </div>

                        <div class="row g-3">
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">Prix unitaire HT</label>
                                <InputNumber class="form-control" @bind-Value="Form.PrixUnitaireHT" />
                                <ValidationMessage For="() => Form.PrixUnitaireHT" />
                            </div>
                            <div class="col-12 col-md-6 mb-3">
                                <label class="form-label">TVA (%)</label>
                                <InputNumber class="form-control" @bind-Value="Form.TauxTVA" />
                                <ValidationMessage For="() => Form.TauxTVA" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Unité</label>
                            <InputText class="form-control" @bind-Value="Form.Unite" />
                            <ValidationMessage For="() => Form.Unite" />
                        </div>

                        <div class="form-check mb-4">
                            <InputCheckbox class="form-check-input" @bind-Value="Form.EstActif" />
                            <label class="form-check-label">Actif</label>
                        </div>

                        <div class="d-flex gap-2">
                            <button type="submit" class="btn btn-success">Enregistrer</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="NewProduit">Réinitialiser</button>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>

        <div class="col-12 col-xl-7">
            <div class="card surface-card shadow-sm border-0">
                <div class="card-header bg-white border-0 pt-3 pb-0 d-flex justify-content-between align-items-center">
                    <h2 class="h5 mb-0">Liste des produits</h2>
                    <span class="badge text-bg-light">@ProductItems.Count produits</span>
                </div>
                <div class="card-body table-responsive">
                    <table class="table align-middle table-hover">
                        <thead>
                            <tr>
                                <th>Référence</th>
                                <th>Désignation</th>
                                <th class="text-end">PU HT</th>
                                <th class="text-end">TVA</th>
                                <th>Statut</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (ProductItems.Count == 0)
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-body-secondary py-4">Aucun produit trouvé.</td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var produit in ProductItems)
                                {
                                    <tr>
                                        <td>@produit.Reference</td>
                                        <td>
                                            <div class="fw-semibold">@produit.Designation</div>
                                            <div class="small text-body-secondary">@produit.Unite</div>
                                        </td>
                                        <td class="text-end">@produit.PrixUnitaireHT.ToString("N3")</td>
                                        <td class="text-end">@produit.TauxTVA.ToString("N0")%</td>
                                        <td>
                                            @if (produit.EstActif)
                                            {
                                                <span class="badge text-bg-success">Actif</span>
                                            }
                                            else
                                            {
                                                <span class="badge text-bg-secondary">Inactif</span>
                                            }
                                        </td>
                                        <td class="text-end">
                                            <div class="btn-group btn-group-sm">
                                                <button class="btn btn-outline-primary" @onclick="() => EditProduit(produit)">Modifier</button>
                                                <button class="btn btn-outline-danger" @onclick="() => DeactivateProduit(produit)">Désactiver</button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<Produit> ProductItems { get; set; } = new();
    private ProduitFormModel Form { get; set; } = new();
    private string? SearchTerm { get; set; }
    private bool ShowInactive { get; set; } = true;
    private string? Message { get; set; }

    protected override async Task OnInitializedAsync()
    {
        await LoadAsync();
    }

    private async Task LoadAsync()
    {
        ProductItems = await ProduitService.GetAllAsync(SearchTerm, ShowInactive);
    }

    private void NewProduit()
    {
        Form = new ProduitFormModel();
        Message = null;
    }

    private void EditProduit(Produit produit)
    {
        Form = new ProduitFormModel
        {
            Id = produit.Id,
            Reference = produit.Reference,
            Designation = produit.Designation,
            PrixUnitaireHT = produit.PrixUnitaireHT,
            TauxTVA = produit.TauxTVA,
            Unite = produit.Unite,
            EstActif = produit.EstActif
        };

        Message = null;
    }

    private async Task SaveAsync()
    {
        var entity = new Produit
        {
            Id = Form.Id,
            Reference = Form.Reference.Trim(),
            Designation = Form.Designation.Trim(),
            PrixUnitaireHT = Form.PrixUnitaireHT,
            TauxTVA = Form.TauxTVA,
            Unite = Form.Unite.Trim(),
            EstActif = Form.EstActif
        };

        if (entity.Id == 0)
        {
            await ProduitService.CreateAsync(entity);
            Message = "Produit créé avec succès.";
        }
        else
        {
            await ProduitService.UpdateAsync(entity);
            Message = "Produit mis à jour avec succès.";
        }

        await LoadAsync();
        NewProduit();
    }

    private async Task DeactivateProduit(Produit produit)
    {
        var confirmed = await JSRuntime.InvokeAsync<bool>("confirm", $"Désactiver {produit.Designation} ?");
        if (!confirmed)
        {
            return;
        }

        await ProduitService.DeleteAsync(produit.Id);
        Message = "Produit désactivé.";
        await LoadAsync();
    }

    private sealed class ProduitFormModel
    {
        public int Id { get; set; }

        [Required, MaxLength(50)]
        public string Reference { get; set; } = string.Empty;

        [Required, MaxLength(200)]
        public string Designation { get; set; } = string.Empty;

        [Range(0, double.MaxValue)]
        public decimal PrixUnitaireHT { get; set; }

        [Range(0, 100)]
        public decimal TauxTVA { get; set; } = 19;

        [Required, MaxLength(30)]
        public string Unite { get; set; } = "pièce";

        public bool EstActif { get; set; } = true;
    }
}